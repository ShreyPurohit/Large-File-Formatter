{
    "name": "large-file-formatter",
    "displayName": "Large File Formatter",
    "description": "Fast and safe formatter for very large files",
    "publisher": "iamshreydxv",
    "version": "0.1.0",
    "license": "MIT",
    "icon": "assets/formatter.png",
    "keywords": [
        "xml",
        "json",
        "formatter",
        "formatting",
        "large files",
        "performance",
        "worker threads",
        "vscode"
    ],
    "engines": {
        "vscode": "^1.60.0"
    },
    "files": [
        "dist/**/*.js",
        "README.md",
        "assets/formatter.png",
        "LICENSE",
        "CHANGELOG.md",
        "package.json"
    ],
    "categories": [
        "Formatters",
        "Other"
    ],
    "activationEvents": [
        "onLanguage:xml",
        "onLanguage:json"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "large-file-formatter.formatCurrentDocument",
                "title": "Large File Formatter: Format Current Document"
            }
        ],
        "configuration": {
            "title": "Large File Formatter",
            "properties": {
                "large-file-formatter.insertFinalNewline": {
                    "type": "boolean",
                    "default": true,
                    "description": "Insert a trailing newline when formatting XML or JSON."
                },
                "large-file-formatter.workerThresholdBytes": {
                    "type": "number",
                    "default": 131072,
                    "minimum": 1024,
                    "description": "Minimum XML document size in bytes before formatting is offloaded to a worker thread."
                },
                "large-file-formatter.jsonWorkerThresholdBytes": {
                    "type": "number",
                    "default": 131072,
                    "minimum": 1024,
                    "description": "Minimum JSON document size in bytes before formatting is offloaded to a worker thread."
                },
                "large-file-formatter.showFormatTiming": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show a popup with formatting duration after every format operation."
                },
                "large-file-formatter.showFormatDetails": {
                    "type": "boolean",
                    "default": true,
                    "description": "Include worker, fallback, size, threshold, edit count, and token count details in format timing popups."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "pnpm run package",
        "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
        "check-types": "tsc --noEmit",
        "lint": "eslint src",
        "test": "vscode-test",
        "format": "prettier --write ."
    },
    "galleryBanner": {
        "color": "#000000",
        "theme": "dark"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.60.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "esbuild": "^0.27.3",
        "eslint": "^9.39.3",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    },
    "badges": [
        {
            "url": "https://img.shields.io/badge/license-MIT-blue.svg",
            "href": "https://opensource.org/licenses/MIT",
            "description": "MIT License"
        }
    ],
    "licenses": [
        {
            "type": "MIT",
            "url": "https://opensource.org/licenses/MIT",
            "description": "MIT License"
        }
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/ShreyPurohit/Large-File-Formatter.git"
    }
}
